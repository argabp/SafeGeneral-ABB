@using Kendo.Mvc.UI
@using Kendo.Mvc.TagHelpers
@using ABB.Application.EditJurnals104.Queries 
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Edit Jurnal 104";
}

<script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/Modules/EditJurnal104/JS/EditJurnal104.index.js"></script>

<style>
    .div-box { padding-bottom: 1em; }
    .swal2-container { z-index: 10050 !important; }
    .breadcrumb-item + .breadcrumb-item::before {
        content: ">"; 
        padding: 0 .5rem; 
    }
</style>

<nav aria-label="breadcrumb">
   <ol class="breadcrumb" style="background: white; ">
        <li class="breadcrumb-item"><a href="#">Accounting</a></li>
        <li class="breadcrumb-item active" aria-current="page">Edit Jurnal 104</li>
    </ol>
</nav>

<div class="flat-box">
    <div class="flat-box-title">
       Pencarian Edit Jurnal 104
    </div>
    
    <div class="p-3" style="background: #f8f9fa; border-bottom: 1px solid #ddd;">
        <div class="row">
            <div class="col-md-2">
                <label>Periode Awal</label>
                <kendo-datepicker name="FilterTglAwal" value="new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1)" format="dd-MM-yyyy" style="width: 100%;" />
            </div>
            <div class="col-md-2">
                <label>Periode Akhir</label>
                <kendo-datepicker name="FilterTglAkhir" value="DateTime.Now" format="dd-MM-yyyy" style="width: 100%;" />
            </div>
            <div class="col-md-3">
                <label>No. Bukti / Voucher (Opsional)</label>
                <input type="text" class="k-textbox w-100" id="SearchKeyword" placeholder="A2-JK00..."/>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="flat-btn-primary w-100" onclick="btnCari_OnClick()"><i class="fa fa-search"></i> Cari Data</button>
            </div>
        </div>
    </div>

    <div class="flat-box-content mt-2">
        @(Html.Kendo().Grid<InquiryJurnal104Dto>()
            .Name("EditJurnal104Grid")
            .Events(e => e.DataBound("onGridDataBound"))
            .DataSource(dataSource => dataSource.Ajax()
                .Read(read => read.Action("GetInquiryData", "EditJurnal104").Type(HttpVerbs.Post).Data("getSearchFilter"))
                .PageSize(20)
                .ServerOperation(false) 
            )
            .Columns(columns =>
            {
                columns.Bound(col => col.NoBukti).Width(250).Title("No. Bukti");
                columns.Bound(col => col.NamaCabang).Width(200).Title("Cabang");
                columns.Bound(col => col.Tanggal).Format("{0:dd-MM-yyyy}").Width(150).Title("Tanggal");
                columns.Bound(col => col.Keterangan).Width(350).Title("Keterangan");
               //s columns.Bound(col => col.TotalNilai).Format("{0:n2}").Width(150).Title("Total Debet").HtmlAttributes(new { style = "text-align: right;" });
                
                columns.Bound("").Title("Action").Width(120).ClientTemplate(
                    "<button class='k-button k-button-icontext k-grid-EditJurnal' onclick='btnEditJurnal_OnClick(event)'><span class='k-icon k-i-edit'></span> Edit</button>"
                ).Locked(true);
            })
            .Pageable(pager => pager.Refresh(true).PageSizes(true))
            .Sortable()
            .Scrollable()
            .Height(450)
            .Resizable(a=>a.Columns(true))
        )
    </div>
</div>

@(Html.Kendo().Window()
    .Name("EditJurnal104Window")
    .Title("Proses Edit Jurnal 104")
    .Width(1100)
    .Modal(true)
    .Visible(false)
    .Draggable(true)
    .Actions(actions => actions.Close())
)