@using Kendo.Mvc.UI
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

<style>
    .custom-kode input, .custom-kode .k-input { background-color: #00FFFF !important; }
    .custom-kuning input, .custom-kuning .k-input { background-color: rgb(255, 255, 225) !important; }
</style>

<div class="window-body">
    <form id="EditJurnalHeaderForm">
        <fieldset>
           <div class="form-group row">
                <label class="col-sm-1 col-form-label pr-0">No. Bukti</label>
                <div class="col-sm-3">
                    <input type="text" id="Edit_NoBukti" class="k-textbox custom-kode" style="width: 100%;" readonly="readonly" value="@ViewBag.NoBukti" />
                </div>
                
                <label class="col-sm-1 col-form-label text-right pr-0">Trans</label>
                <div class="col-sm-2">
                    <input type="text" id="Edit_GlTran" class="k-textbox custom-kode" style="width: 100%; text-align:center;" readonly="readonly" />
                </div>
                
                <label class="col-sm-1 col-form-label text-right pr-0">Lokasi</label>
                <div class="col-sm-1">
                    <input type="text" id="Edit_KodeLokasi" class="k-textbox custom-kode" style="width: 100%; text-align:center;" readonly="readonly" />
                </div>
                
                <label class="col-sm-1 col-form-label text-right pr-0">Tanggal</label>
                <div class="col-sm-2">
                    <input type="text" id="Edit_Tanggal" class="k-textbox custom-kode" style="width: 100%;" readonly="readonly" />
                </div>
            </div>
            <div class="form-group row">
                <label class="col-sm-2 col-form-label">Keterangan Jurnal</label>
                <div class="col-sm-10">
                 <textarea id="Edit_KeteranganUtama" class="k-textbox custom-kuning" rows="4" style="width: 100%; resize: vertical; min-height: 80px;"></textarea>
                </div>
            </div>
        </fieldset>
    </form>
   
    <hr/>
    <div style="margin-bottom: 10px;">
        <button class="k-button k-primary" onclick="btnTambahBaris_OnClick()"><i class="fa fa-plus"></i> Tambah Baris Manual</button>
    </div>

    <div id="EditDetailGrid"></div>

    <div style="margin-top: 10px; padding: 10px; background: #eee; border: 1px solid #ddd; font-weight: bold; display: flex; justify-content: flex-end; gap: 30px;">
        <span>Total Debet: <span id="lblTotalDebet" style="color:blue">0.00</span></span>
        <span>Total Kredit: <span id="lblTotalKredit" style="color:blue">0.00</span></span>
        <span>Balance: <span id="lblBalance" style="color:green">0.00</span></span>
    </div>

    <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px;">
        <button type="button" class="btn btn-secondary" onclick="btnCloseWindow()">Batal</button>
        <button type="button" onclick="onSaveAllEditJurnal()" class="btn btn-success">
            <i class="fa fa-save"></i> Simpan Perubahan Jurnal
        </button>
    </div>
</div>