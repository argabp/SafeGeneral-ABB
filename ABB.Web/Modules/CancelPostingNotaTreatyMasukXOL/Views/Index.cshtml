@using ABB.Application.CancelPostingNotaTreatyMasukXOLs.Queries
@using Kendo.Mvc.UI
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cancel Posting Nota Treaty Masuk XOL";
}
<script src="~/Modules/CancelPostingNotaTreatyMasukXOL/JS/cancelPostingNotaTreatyMasukXOL.js"></script>

<style>
    .div-box{
        padding-bottom: 1em;
    }
</style>
<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-6">
            Cancel Posting Nota Treaty Masuk XOL
        </div>

        <div class="col-md-4">
            <input type="text" class="search-field-top " id="SearchKeyword" placeholder="Search"/>
        </div>

        <div class="col-md-2">
            <button class="flat-btn-primary" onclick="cancelPostingNotaTreatyMasukXOL()">Cancel Posting</button>
        </div>
    </div>

    <div class="flat-box-content">
        <div class="div-box">
            @(Html.Kendo().Grid<CancelPostingNotaTreatyMasukXOLDto>()
                .Name("CancelPostingNotaTreatyMasukXOLGrid")
                .DataSource(dataSource => dataSource.Ajax()
                    .Read(read => read.Action("GetCancelPostingNotaTreatyMasukXOLs", "CancelPostingNotaTreatyMasukXOL").Data("searchFilterCancelPostingNotaTreatyMasukXOL"))
                    .Model(model => model.Id(p => p.nomor_nota))
                )
                .Columns(columns =>
                {
                    columns.Select().Width(50);
                    columns.Bound(col => col.nomor_nota).Width(150).Title("Nomor Nota");
                    columns.Bound(col => col.nm_ttj).Width(150).Title("Nama Tertuju");
                    // columns.Bound(col => col.tgl_nt).Width(150).Title("Tanggal Nota").Format("{0: dd-MM-yyyy}");
                })
                .Pageable(pager => pager
                    .Refresh(true)
                    .Info(true)
                    .PageSizes(true)
                )
                .PersistSelection()
                .Sortable()
                .Filterable()
                .Scrollable()
                .Height(450)
                .Resizable(a=>a.Columns(true))
                .Events(ev => ev.DataBound("gridAutoFit").Change("onChangeGridCancelPostingNotaTreatyMasukXOL"))
        
                )    
        </div>
    </div>
</div>

