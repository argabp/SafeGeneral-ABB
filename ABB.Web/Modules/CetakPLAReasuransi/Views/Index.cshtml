@using ABB.Application.Common.Dtos
@using Kendo.Mvc.UI
@using ABB.Application.CetakPLAReasuransis.Queries
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "PLA Koasuransi";
}
<script src="~/Modules/CetakPLAReasuransi/JS/cetakPLAReasuransi.js"></script>

<style>
    .div-box{
        padding-bottom: 1em;
    }
</style>
<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-8">
            Cetak PLA Reasuransi
        </div>

        <div class="col-md-4">
            <input type="text" class="search-field-top " id="SearchKeyword" placeholder="Search"/>
        </div>
    </div>

    <div class="flat-box-content">
        <div class="div-box">
            @(Html.Kendo().Grid<PLAReasuransiDto>()
                .Name("CetakPLAReasuransiGrid")
                .DataSource(dataSource => dataSource.Ajax()
                    .Read(read => read.Action("GetCetakPLAReasuransi", "CetakPLAReasuransi").Data("searchFilter"))
                    .Model(model => model.Id(p => p.nomor_pla))
                )
                .Columns(columns =>
                {
                    columns.Bound(col => col.nm_cb).Width(150).Title("Nama Cabang");
                    columns.Bound(col => col.nm_cob).Width(150).Title("Nama COB");
                    columns.Bound(col => col.nm_scob).Width(150).Title("Nama Sub COB");
                    columns.Bound(col => col.nomor_pla).Width(200).Title("Nomor PLA");
                    columns.Bound(col => col.nm_grp_rk).Width(200).Title("Nama Tertuju");
                    columns.Bound(col => col.nm_rk).Width(200).Title("Nama Tertuju");
                    columns.Bound(col => col.nm_ttg).Width(200).Title("Nama Tertanggung");
                })
                .Pageable(pager => pager
                    .Refresh(true)
                    .Info(true)
                    .PageSizes(true)
                )
                .ClientDetailTemplateId("template")
                .Sortable()
                .Filterable()
                .Scrollable()
                .Height(450)
                .Resizable(a=>a.Columns(true))
                .Events(ev => ev.DataBound("gridAutoFit"))
        
                )    
        </div>
        
        <script id="template" type="text/kendo-tmpl">
            <form id="#=nomor_pla#" enctype="multipart/form-data" autocomplete="off">
                <div class="form-group row">
                    <div class="col-sm-3">
                        <button type="button" onclick="viewReport(this)" class="btn btn-info space-right">
                            <span class="fa fa-print"></span> Preview
                        </button>
                    </div>
                </div>
            </form>
        </script>
    </div>
</div>

