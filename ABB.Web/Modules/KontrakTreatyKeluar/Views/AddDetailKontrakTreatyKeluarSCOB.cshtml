@using Kendo.Mvc.UI
@model ABB.Web.Modules.KontrakTreatyKeluar.Models.DetailKontrakTreatyKeluarSCOBViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

<script src="~/Modules/KontrakTreatyKeluar/JS/kontrakTreatyKeluar.DetailSCOB.js"></script>

@Html.AntiForgeryToken()
<form id="DetailKontrakTreatyKeluarSCOBForm" enctype="multipart/form-data">
    <div class="window-body" style="background-color: lightgray">
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-6">SCOB</label>
                <div class="col-sm-6">
                    <kendo-dropdownlist for="kd_scob" style="width: 100%" option-label="Pilih SCOB" class="primary-dropdown"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains" >
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetSCOB", "KontrakTreatyKeluar")" data="dataKodeSCOBDropDown"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                    <span asp-validation-for="kd_scob" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>
    <div class="window-footer">
        <button type="button" id="btn-save-detailKontrakTreatyKeluarSCOB" class="btn btn-primary space-right">Save</button>
    </div>
</form>
