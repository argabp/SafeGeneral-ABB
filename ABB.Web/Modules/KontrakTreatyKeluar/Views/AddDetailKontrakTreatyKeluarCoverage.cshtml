@using Kendo.Mvc.UI
@model ABB.Web.Modules.KontrakTreatyKeluar.Models.DetailKontrakTreatyKeluarCoverageViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

<script src="~/Modules/KontrakTreatyKeluar/JS/kontrakTreatyKeluar.DetailCoverage.js"></script>

@{
    var coverage_pst_kms_reas = (double)Model.pst_kms_reas;
}

@Html.AntiForgeryToken()
<form id="DetailKontrakTreatyKeluarCoverageForm" enctype="multipart/form-data">
    <div class="window-body" style="background-color: lightgray">
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-6">Coverage</label>
                <div class="col-sm-6">
                    <kendo-dropdownlist for="kd_cvrg" style="width: 100%" option-label="Pilih Coverage" class="primary-dropdown"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetCoverage", "KontrakTreatyKeluar")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                    <span asp-validation-for="kd_cvrg" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-6">Komisi Reas (%)</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox spinners="false" max="100" decimals="2" name="coverage_pst_kms_reas" value="coverage_pst_kms_reas" style="width: 100%; background-color: #FFFFE1"/>
                    <span asp-validation-for="pst_kms_reas" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-6">Limit Treaty Jabodetabek</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox spinners="false" decimals="2" for="max_limit_jktb" style="width: 100%;"/>
                    <span asp-validation-for="max_limit_jktb" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-6">Limit Treaty Provinsi</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox spinners="false" decimals="2" for="max_limit_prov" style="width: 100%;"/>
                    <span asp-validation-for="max_limit_prov" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>
    <div class="window-footer">
        <button type="button" id="btn-save-detailKontrakTreatyKeluarCoverage" class="btn btn-primary space-right">Save</button>
    </div>
</form>
