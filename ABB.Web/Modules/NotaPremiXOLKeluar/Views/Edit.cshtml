@using ABB.Application.EntriNotas.Queries
@using ABB.Domain.Entities
@using ABB.Web.Modules.EntriNota.Models
@using Kendo.Mvc.TagHelpers
@using Kendo.Mvc.UI
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ABB.Web.Modules.NotaPremiXOLKeluar.Models.NotaPremiXOLKeluarViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc
@{
    var nomor_nota = Model.kd_cb.Trim() + " . " + Model.jns_tr.Trim() + " . " + Model.kd_thn.Trim() + " . " + 
                     Model.kd_bln.Trim() + " . " + Model.no_nt_msk.Trim()+ " / " + Model.jns_nt_kel.Trim() + " . " + 
                     Model.no_nt_kel.Trim();
}

<script src="~/Modules/NotaPremiXOLKeluar/JS/notaPremiXOLKeluar.edit.js"></script>

@Html.AntiForgeryToken()
<form id="NotaPremiXOLKeluarForm" enctype="multipart/form-data">
    <div class="window-body" style="background-color: lightgray">
        @Html.HiddenFor(m => m.jns_sb_nt)
        @Html.HiddenFor(m => m.kd_cb)
        @Html.HiddenFor(m => m.kd_scob)
        @Html.HiddenFor(m => m.jns_tr)
        @Html.HiddenFor(m => m.jns_nt_msk)
        @Html.HiddenFor(m => m.kd_thn)
        @Html.HiddenFor(m => m.kd_bln)
        @Html.HiddenFor(m => m.no_nt_msk)
        @Html.HiddenFor(m => m.no_nt_kel)
        @Html.HiddenFor(m => m.no_pol)
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Jenis Nota</label>
                <div class="col-sm-6">
                    <kendo-dropdownlist for="jns_nt_kel" style="width: 100%" readonly="true"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetJenisNota", "NotaPremiXOLKeluar")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Nomor Nota</label>
                <div class="col-sm-6">
                    <kendo-textbox name="temp_nomor_nota" value="@nomor_nota" readonly="true" style="width: 100%"/>
                </div>
            </div>
            <div class="row col-sm-6">
                <label class="col-sm-6">Mata Uang</label>
                <div class="col-sm-6">
                    <kendo-dropdownlist for="kd_mtu" style="width: 100%" readonly="true"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetMataUang", "NotaPremiXOLKeluar")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                </div>
            </div>
        </div>
        
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Nomor Referensi</label>
                <div class="col-sm-6">
                    <kendo-textbox for="no_ref" style="width: 100%" readonly="true"/>
                    <span asp-validation-for="no_ref" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Sumber Bisnis</label>
                <div class="col-sm-6">
                    <input type="hidden" id="temp_kd_grp_sb_bis" value="@Model.kd_grp_sb_bis">
                    <kendo-dropdownlist for="kd_grp_sb_bis" style="width: 100%" option-label="Pilih Kode Tertuju"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains" readonly="true">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetSumberBisnis", "NotaPremiXOLKeluar")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                    <span asp-validation-for="kd_grp_sb_bis" class="text-danger"></span>
                </div>
            </div>
            <div class="row col-sm-6">
                <div class="col-sm-6">
                    <input type="hidden" id="temp_kd_rk_sb_bis" value="@Model.kd_rk_sb_bis">
                    <kendo-dropdownlist for="kd_rk_sb_bis" style="width: 100%" readonly="true"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetKodeRekananTertuju", "NotaPremiXOLKeluar")" data="dataKodeSumberBisnisDropDown"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                    <span asp-validation-for="kd_rk_sb_bis" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Kode Tertuju</label>
                <div class="col-sm-6">
                    <input type="hidden" id="temp_kd_grp_ttj" value="@Model.kd_grp_ttj">
                    <kendo-dropdownlist for="kd_grp_ttj" style="width: 100%" option-label="Pilih Kode Tertuju"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains" readonly="true">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetKodeTertuju", "NotaPremiXOLKeluar")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                    <span asp-validation-for="kd_grp_ttj" class="text-danger"></span>
                </div>
            </div>
            <div class="row col-sm-6">
                <div class="col-sm-6">
                    <input type="hidden" id="temp_kd_rk_ttj" value="@Model.kd_rk_ttj">
                    <kendo-dropdownlist for="kd_rk_ttj" style="width: 100%" readonly="true"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetKodeRekananTertuju", "NotaPremiXOLKeluar")" data="dataKodeTertujuDropDown"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                    <span asp-validation-for="kd_rk_ttj" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Kode COB</label>
                <div class="col-sm-6">
                    <kendo-dropdownlist for="kd_cob" style="width: 100%" readonly="true"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetCOB", "NotaPremiXOLKeluar")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                </div>
            </div>
        </div>
        
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Nama Tertuju</label>
                <div class="col-sm-6">
                    <kendo-textbox for="nm_ttj" style="width: 100%" readonly="true"/>
                    <span asp-validation-for="nm_ttj" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Alamat</label>
                <div class="col-sm-6">
                    <kendo-textarea name="almt_ttj" rows="2" style="width: 100%; background-color: var(--soft-grey) !important;" readonly="true">@Model.almt_ttj</kendo-textarea>
                    <span asp-validation-for="almt_ttj" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Kota</label>
                <div class="col-sm-6">
                    <kendo-textbox for="kt_ttj" style="width: 100%" readonly="true"/>
                    <span asp-validation-for="kt_ttj" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Keterangan Nota</label>
                <div class="col-sm-6">
                    <kendo-textarea name="ket_nt" rows="2" style="width: 100%; background-color: white">@Model.ket_nt</kendo-textarea>
                    <span asp-validation-for="ket_nt" class="text-danger"></span>
                </div>
            </div>
        </div>
        
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Nilai Nota Kredit</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox spinners="false" decimals="2" for="nilai_nt" readonly="true" style="width: 100%;"/>
                    <span asp-validation-for="nilai_prm" class="text-danger"></span>
                </div>
            </div>
            <div class="row col-sm-6">
                <label class="col-sm-6">Uraian</label>
                <div class="col-sm-6">
                    <kendo-textbox for="uraian" style="width: 100%"/>
                    <span asp-validation-for="uraian" class="text-danger"></span>
                </div>
            </div>
        </div>
        
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-3">Nilai PPN</label>
                <div class="col-sm-3">
                    <kendo-numerictextbox spinners="false" readonly="true" decimals="2" for="pst_ppn" style="width: 100%; background-color: #FFFFE1"/>
                    <span asp-validation-for="pst_ppn" class="text-danger"></span>
                </div>
                <div class="col-sm-6">
                    <kendo-numerictextbox spinners="false" readonly="true" decimals="2" for="nilai_ppn" style="width: 100%; background-color: #FFFFE1"/>
                    <span asp-validation-for="nilai_ppn" class="text-danger"></span>
                </div>
            </div>
            <div class="row col-sm-6">
                <label class="col-sm-6">Tanggal Nota</label>
                <div class="col-sm-6">
                    <kendo-datepicker for="tgl_nt" style="width: 100%" readonly="true"/>
                    <span asp-validation-for="tgl_nt" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-3">Nilai PPH</label>
                <div class="col-sm-3">
                    <kendo-numerictextbox spinners="false" readonly="true" decimals="2" for="pst_pph" style="width: 100%; background-color: #FFFFE1"/>
                    <span asp-validation-for="pst_pph" class="text-danger"></span>
                </div>
                <div class="col-sm-6">
                    <kendo-numerictextbox spinners="false" readonly="true" decimals="2" for="nilai_pph" style="width: 100%; background-color: #FFFFE1"/>
                    <span asp-validation-for="nilai_pph" class="text-danger"></span>
                </div>
            </div>
            <div class="row col-sm-6">
                <label class="col-sm-6">Flag Posting</label>
                <input type="hidden" id="tempFlag_posting" value="@Model.flag_posting">
                <div class="col-sm-6">
                    <label>
                        <input type="checkbox" class="k-checkbox" disabled id="flag_posting"/> Posting
                    </label>
                </div>
            </div>
        </div>
    </div>
    <div class="window-footer">
        <button type="button" id="btn-save-notaPremiXOLKeluar" class="btn btn-primary space-right">Save</button>
    </div>
</form>