            <vc:inquiry-fakultatif-coverage model="@Model"></vc:inquiry-fakultatif-coverage>
        </div>
        <div id="tabObyek">
            <vc:inquiry-fakultatif-obyek model="@Model"></vc:inquiry-fakultatif-obyek>
