            <vc:inquiry-fakultatif-other model="@Model"></vc:inquiry-fakultatif-other>
        </div>
    </div>
    
    <div class="window-footer">
        <button type="button" id="btn-previous-akseptasiResikoView" class="btn btn-primary space-right">
