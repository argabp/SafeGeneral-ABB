@using Kendo.Mvc.TagHelpers
@using Kendo.Mvc.UI
@model ABB.Web.Modules.Inquiry.Models.InquiryResikoParameterViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc
@addTagHelper *, ABB.Web

<script src="~/Modules/InquiryPremiFakultatifMasuk/Components/InquiryFakultatifResikoView/resikoView.js"></script>

<div class="window-body">
    <div id="resikoTab">
        <ul>
            <li class="k-active">
                Resiko
            </li>
            <li>
                Coverage
            </li>
            <li>
                Obyek
            </li>
            <li>
                Others
            </li>
