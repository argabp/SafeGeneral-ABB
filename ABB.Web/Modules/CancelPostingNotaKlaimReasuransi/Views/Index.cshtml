@using ABB.Application.CancelPostingNotaKlaimReasuransis.Queries
@using Kendo.Mvc.UI
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cancel Posting Nota Klaim Reasuransi";
}
<script src="~/Modules/CancelPostingNotaKlaimReasuransi/JS/cancelPostingNotaKlaimReasuransi.js"></script>

<style>
    .div-box{
        padding-bottom: 1em;
    }
</style>
<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-6">
            Cancel Posting Nota Klaim Reasuransi
        </div>

        <div class="col-md-4">
            <input type="text" class="search-field-top " id="SearchKeyword" placeholder="Search"/>
        </div>

        <div class="col-md-2">
            <button class="flat-btn-primary" onclick="cancelPostingNotaKlaimReasuransi()">Cancel Posting</button>
        </div>

        @* <div class="col-md-2"> *@
        @*     <button class="flat-btn-primary" onclick="postingAccounting()">Posting Accounting</button> *@
        @* </div> *@
    </div>

    <div class="flat-box-content">
        <div class="div-box">
            @(Html.Kendo().Grid<CancelPostingNotaKlaimReasuransiDto>()
                .Name("CancelPostingNotaKlaimReasuransiGrid")
                .DataSource(dataSource => dataSource.Ajax()
                    .Read(read => read.Action("GetCancelPostingNotaKlaimReasuransis", "CancelPostingNotaKlaimReasuransi").Data("searchFilterCancelPostingNotaKlaimReasuransi"))
                    .Model(model => model.Id(p => p.Id))
                )
                .Columns(columns =>
                {
                    columns.Select().Width(50);
                    columns.Bound(col => col.nm_cb).Width(150).Title("Nama Cabang");
                    columns.Bound(col => col.nm_cob).Width(150).Title("Nama COB");
                    columns.Bound(col => col.nm_scob).Width(150).Title("Nama Sub COB");
                    columns.Bound(col => col.nomor_register).Width(200).Title("Nomor Mutasi Klaim");
                    columns.Bound(col => col.nm_ttg).Width(150).Title("Nama Tertanggung");
                })
                .Pageable(pager => pager
                    .Refresh(true)
                    .Info(true)
                    .PageSizes(true)
                )
                .PersistSelection()
                .Sortable()
                .Filterable()
                .Scrollable()
                .Height(450)
                .Resizable(a=>a.Columns(true))
                .Events(ev => ev.DataBound("gridAutoFit").Change("onChangeGridCancelPostingNotaKlaimReasuransi"))
        
                )    
        </div>
    </div>
</div>

