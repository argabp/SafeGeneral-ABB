@using Kendo.Mvc.UI
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc
@model ABB.Web.Modules.ListingSpreadingOfRisk.Models.ListingSpreadingOfRiskViewModel

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Listing Spreading Of Risk";
}
<script src="~/Modules/ListingSpreadingOfRisk/JS/listingSpreadingOfRisk.js"></script>

<style>
    .div-box{
        padding-bottom: 1em;
    }
</style>
<div class="flat-box">
    <div class="row" style="padding-bottom: 1em;">
        <div class="flat-box-title col-md-8">
            Listing Spreading Of Risk
        </div>
    </div>
    <form id="ListingSpreadingOfRiskForm" enctype="multipart/form-data" autocomplete="off">
        <div class="form-group row">
            <div class="row col-sm-9">
                <label class="col-sm-3">Cabang</label>
                <div class="col-sm-6">
                    <kendo-dropdownlist for="kd_cb" style="width: 100%" option-label="Pilih Cabang"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetCabang", "ListingSpreadingOfRisk")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                    <span asp-validation-for="kd_cb" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-9">
                <label class="col-sm-3">COB</label>
                <div class="col-sm-6">
                    <kendo-dropdownlist for="kd_cob" style="width: 100%" option-label="Pilih COB"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetCOB", "ListingSpreadingOfRisk")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                    <span asp-validation-for="kd_cob" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-9">
                <label class="col-sm-3">Periode</label>
                <div class="col-sm-6 row" style="padding-right: 0">
                    <div class="col-sm-5">
                        <kendo-datepicker for="tgl_mul" value="DateTime.Now"/>
                        <span asp-validation-for="tgl_mul" class="text-danger"></span>
                    </div>
                    <div class="col-sm-2" style="align-content: center; text-align: center">
                        <p style="margin-bottom: 3px">s/d</p>
                    </div>
                    <div class="col-sm-5" style="padding-right: 0">
                        <kendo-datepicker for="tgl_akh" value="DateTime.Now"/>
                        <span asp-validation-for="tgl_akh" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-9">
                <label class="col-sm-3">No Polis</label>
                <div class="col-sm-6">
                    <kendo-maskedtextbox mask="00.000.00.0000.0000-0" for="no_pol_ttg" style="width: 100%"/>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-9">
                <label class="col-sm-3">Lokasi Resiko</label>
                <div class="col-sm-6">
                    <kendo-textarea name="almt_rsk" rows="2" style="width: 100%; background-color: white"></kendo-textarea>
                    <span asp-validation-for="almt_rsk" class="text-danger"></span>
                </div>
            </div>
        </div>
        
        <div class="form-group">
            <button type="button" id="btn-preview" class="btn btn-success space-right">
                <span class="fa fa-search"></span> Preview
            </button>
        </div>
    </form>
</div>

