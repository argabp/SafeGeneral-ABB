@using Kendo.Mvc.UI
@model ABB.Web.Modules.DataProduksiCabang.Models.DataProduksiCabangViewModel
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
Layout = "~/Modules/Shared/_Layout.cshtml";
ViewData["Title"] = "Data Produksi Cabang";
}
<script src="~/Modules/DataProduksiCabang/JS/dataProduksiCabang.js"></script>

<div class="flat-box" id="container-cancel-csm">
    <div class="row">
        <div class="flat-box-title col-md-6">
            Data Produksi Cabang
        </div>
    </div>

    <div class="flat-box-content">
        <form id="DataProduksiCabangForm" enctype="multipart/form-data" autocomplete="off">
            <div class="form-group row">
                <div class="row col-sm-8">
                    <label class="col-sm-3">Cabang</label>
                    <div class="col-sm-6">
                        <kendo-dropdownlist for="kd_cb" style="width: 100%" option-label="Pilih Cabang" readonly="true"
                                            datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                            <datasource type="DataSourceTagHelperType.Custom">
                                <transport>
                                    <read url="@Url.Action("GetCabang", "DataProduksiCabang")"/>
                                </transport>
                            </datasource>
                        </kendo-dropdownlist>
                        <span asp-validation-for="kd_cb" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <div class="row col-sm-8">
                    <label class="col-sm-3">COB</label>
                    <div class="col-sm-6">
                        <kendo-dropdownlist for="kd_cob" style="width: 100%" option-label="Pilih COB"
                                            datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                            <datasource type="DataSourceTagHelperType.Custom">
                                <transport>
                                    <read url="@Url.Action("GetCOB", "DataProduksiCabang")"/>
                                </transport>
                            </datasource>
                        </kendo-dropdownlist>
                        <span asp-validation-for="kd_cob" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <div class="row col-sm-8">
                    <label class="col-sm-3">Periode</label>
                    <div class="col-sm-6 row" style="padding-right: 0">
                        <div class="col-sm-5" style="padding-right: 0">
                            <kendo-datepicker for="tgl_mul" value="DateTime.Now"/>
                            <span asp-validation-for="tgl_mul" class="text-danger"></span>
                        </div>
                        <div class="col-sm-2" style="align-content: center; text-align: right">
                            <p style="margin-bottom: 3px">s/d</p>
                        </div>
                        <div class="col-sm-5" style="padding-right: 0">
                            <kendo-datepicker for="tgl_akh" value="DateTime.Now"/>
                            <span asp-validation-for="tgl_akh" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row form-group">
                <div class="row col-sm-6">
                    <div class="col-sm-3">
                        <button type="button" id="btn-refresh-grid" class="btn btn-primary" style="width: 100%">
                            <span class="fa fa-redo"></span>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

