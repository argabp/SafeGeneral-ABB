@using Kendo.Mvc.UI
@using ABB.Application.TemplateJurnals117.Queries
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Otomatisasi Jurnal 117 ";
}
<script src="~/Modules/TemplateJurnal117/JS/TemplateJurnal117.index.js"></script>

<script>
function getDetailParams(e) {
    var gridDetail = this;
    var detailRow = $(gridDetail.element).closest(".k-detail-row"); 
    var masterRow = detailRow.prev();
    var masterGrid = $("#TemplateJurnal117Grid").data("kendoGrid");
    var dataItem = masterGrid.dataItem(masterRow);

    if (dataItem) {
        return {
            type_tr: dataItem.type_tr ? dataItem.type_tr.trim() : "", 
            type_jr: dataItem.type_jr ? dataItem.type_jr.trim() : "",
            metode: dataItem.metode ? dataItem.metode.trim() : "",
            Event: dataItem.Event ? dataItem.Event.trim() : "",
            jn_ass: dataItem.jn_ass ? dataItem.jn_ass.trim() : ""
        };
    }
    return {};
}
</script>

<style>
    .div-box{
        padding-bottom: 1em;
    }
    #kd_mtu, #tgl_mul, #tgl_akh{
        background-color: #00FFFF;
    }
    #symbol, #nilai_kurs, .k-input{
        background-color: #FFFFE1;
    }
</style>

<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-6">
            Otomatisasi Jurnal 117
        </div>
    </div>

    <div class="flat-box-content">
        <div class="div-box">
            @(Html.Kendo().Grid<TemplateJurnal117Dto>()
                .Name("TemplateJurnal117Grid")
                .ToolBar(toolbar => toolbar.Create())
                .Editable(editable => editable.Mode(GridEditMode.InLine))
                .DataSource(dataSource => dataSource.Ajax()
                    // Pastikan searchFilter ada di scope global
                    .Read(read => read.Action("GetTemplateJurnal117", "TemplateJurnal117").Data("searchFilter")) 
                    .Model(model => model.Id(p => p.GridId))
                )
                .Columns(columns =>
                {
                    columns.Command(command =>
                    {
                        command.Edit();
                        command.Custom("DeleteTempleteJurnal117")
                            .Text("Delete")
                            .IconClass("k-icon k-i-delete")
                            .HtmlAttributes(new { title = "Delete" })
                            .Click("onDeleteTemplateJurnal117");
                    }).Width(200).Title("Action");
                    columns.Bound(col => col.type_tr).Width(150).Title("Type Tr").Editable("disableGridTextboxWhenEdit");
                    columns.Bound(col => col.type_jr).Width(150).Title("Type Jr").Editable("disableGridTextboxWhenEdit");
                    columns.Bound(col => col.metode).Width(150).Title("Metode").Editable("disableGridTextboxWhenEdit");
                    columns.Bound(col => col.Event).Width(150).Title("Event").Editable("disableGridTextboxWhenEdit");
                    columns.Bound(col => col.jn_ass).Width(150).Title("Jenis ASS").Editable("disableGridTextboxWhenEdit");
                    columns.Bound(col => col.nm_jr).Width(150).Title("Nama Jurnal");
                })
                .Pageable(pager => pager.Refresh(true).Info(true).PageSizes(true))
                .ClientDetailTemplateId("template") // Ini yang mengaktifkan panah detail Kendo
                .Sortable()
                .Filterable()
                .Scrollable()
                .Height(450)
                .Resizable(a => a.Columns(true))
                .Events(ev => ev.DataBound("gridAutoFit").Save("onSaveTemplateJurnal117"))
            )
        </div>

        <script id="template" type="text/kendo-tmpl">
            @(Html.Kendo().TabStrip()
                .Name("tabStrip_#=GridId#")
                .SelectedIndex(0)
                .Items(items =>
                {
                    items.Add().Text("Detail").Content(@<text>
                        @(Html.Kendo().Grid<TemplateJurnalDetail117Dto>()
                            .Name("grid_detail_#=GridId#")
                            .ToolBar(t => t.Create())
                            .Editable(e => e.Mode(GridEditMode.InLine))
                            .DataSource(ds => ds.Ajax()
                                .Read(read => read.Action("GetDetailTemplateJurnal117", "TemplateJurnal117",
                                    new { type_tr = "#=type_tr#", type_jr = "#=type_jr#", metode = "#=metode#", Event = "#=Event#", jn_ass = "#=jn_ass#" }))
                                .Model(m =>
                                {
                                    m.Id(p => p.gl_akun); 
                                    
                                    m.Field(p => p.type_tr).DefaultValue("#=type_tr#");      
                                    m.Field(p => p.type_jr).DefaultValue("#=type_jr#");
                                    m.Field(p => p.metode).DefaultValue("#=metode#");
                                    m.Field(p => p.Event).DefaultValue("#=Event#");
                                    m.Field(p => p.jn_ass).DefaultValue("#=jn_ass#");
                                    m.Field(p => p.GridId).DefaultValue("#=GridId#");

                                    m.Field(p => p.type_tr).Editable(false);
                                    m.Field(p => p.type_jr).Editable(false);
                                    m.Field(p => p.metode).Editable(false);
                                    m.Field(p => p.Event).Editable(false);
                                    m.Field(p => p.jn_ass).Editable(false);
                                    
                                    m.Field(p => p.gl_dk).DefaultValue("D");
                                    m.Field(p => p.gl_urut).DefaultValue(0);
                                })
                            )
                            .Columns(columns =>
                            {
                                columns.Command(command =>
                                {
                                    command.Edit();
                                    command.Custom("DeleteTemplateJurnalDetail117")
                                        .Text("Delete")
                                        .IconClass("k-icon k-i-delete")
                                        .HtmlAttributes(new { title = "Delete" })
                                        .Click("onDeleteTemplateJurnalDetail117");
                                }).Width(200).Title("Action");
                                
                                columns.Bound(m => m.type_tr).Title("Type TR").Width(100);
                                columns.Bound(m => m.type_jr).Title("Type JR").Width(100);
                                columns.Bound(m => m.metode).Title("Metode").Width(100);
                                columns.Bound(m => m.Event).Title("Event").Width(100);
                                columns.Bound(m => m.jn_ass).Title("Jenis Ass").Width(100);
                                columns.Bound(m => m.gl_akun).Title("GL Akun").Width(150);
                                columns.Bound(m => m.gl_rumus).Title("Rumus").Width(150);
                                columns.Bound(m => m.gl_dk).Title("D/K").Width(100);
                                columns.Bound(m => m.gl_urut).Title("Urut").Width(80);
                                columns.Bound(m => m.flag_detail).Title("Flag Detail").Width(120);
                                columns.Bound(m => m.flag_nt).Title("Flag NT").Width(100);
                            })
                            .Pageable(p => p.Refresh(true).Info(true).PageSizes(true))
                            .Sortable()
                            .Selectable()
                            .Filterable()
                            .Scrollable()
                            .Height(380)
                            .Resizable(a => a.Columns(true))
                            .Events(ev => ev
                                .DataBound("gridAutoFit")
                                .Save("onSaveTemplateJurnalDetail117") 
                                .Edit("onEditTemplateJurnalDetail117") 
                            )
                            .ToClientTemplate()
                        )
                    </text>);
                })
                .ToClientTemplate())
        </script>

    </div>
</div>