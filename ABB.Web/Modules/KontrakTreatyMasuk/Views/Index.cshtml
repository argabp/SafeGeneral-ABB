@using ABB.Application.KontrakTreatyMasuks.Queries
@using Kendo.Mvc.UI
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Kontrak Treaty Masuk";
}
<script src="~/Modules/KontrakTreatyMasuk/JS/kontrakTreatyMasuk.index.js"></script>

<style>
    .div-box{
        padding-bottom: 1em;
    }
</style>

<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-6">
            Kontrak Treaty Masuk
        </div>

        <div class="col-md-4">
            <input type="text" class="search-field-top " id="SearchKeyword" placeholder="Search"/>
        </div>

        <div class="col-md-2">
            <button class="flat-btn-primary" onclick="btnAddKontrakTreatyMasuk_OnClick()" >Add</button>
        </div>
    </div>

    <div class="flat-box-content">
        <div class="div-box">
            @(Html.Kendo().Grid<KontrakTreatyMasukDto>()
                .Name("KontrakTreatyMasukGrid")
                .DataSource(dataSource => dataSource.Ajax()
                    .Read(read => read.Action("GetKontrakTreatyMasuks", "KontrakTreatyMasuk").Data("searchFilterKontrakTreatyMasuk"))
                    .Model(model => model.Id(p => p.Id))
                )
                .Columns(columns =>
                {
                    columns.Command(command =>
                    {
                        command.Custom("EditKontrakTreatyMasuk")
                            .Text("Edit")
                            .IconClass("k-icon k-i-edit")
                            .HtmlAttributes(new { title="Edit"})
                            .Click("onEditKontrakTreatyMasuk");
                        command.Custom("DeleteKontrakTreatyMasuk")
                            .Text("Delete")
                            .IconClass("k-icon k-i-delete")
                            .HtmlAttributes(new { title="Delete"})
                            .Click("onDeleteKontrakTreatyMasuk");
                    }).Width(150).Title("Action").Locked(true);
                    columns.Bound(col => col.nm_cb).Width(150).Title("Nama Cabang");
                    columns.Bound(col => col.nm_jns_sor).Width(150).Title("Nama Jenis SOR");
                    columns.Bound(col => col.kd_tty_msk).Width(200).Title("Kode Treaty Masuk");
                })
                .Pageable(pager => pager
                    .Refresh(true)
                    .Info(true)
                    .PageSizes(true)
                )
                .Sortable()
                .Filterable()
                .Scrollable()
                .Height(450)
                .Resizable(a=>a.Columns(true))
                .Events(ev => ev.DataBound("gridAutoFit"))
                ) 
        </div>
        
        @(Html.Kendo().Window()
            .Name("KontrakTreatyMasukWindow")
            .Title("Kontrak Treaty Masuk")
            .Width(800)
            .Modal(true)
            .Visible(false)
            .Draggable(true)
            )
    </div>
</div>
