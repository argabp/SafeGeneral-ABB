@using Microsoft.Extensions.Configuration
@model ABB.Web.Modules.ProsesNotaPremiTreaty.Models.ProsesNotaPremiTreatyViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc
@using Kendo.Mvc.UI

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Proses Nota Premi Treaty";
}
<script src="~/Modules/ProsesNotaPremiTreaty/JS/prosesNotaPremiTreaty.index.js"></script>

<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-6">
            Proses Nota Premi Treaty
        </div>
    </div>

    <div class="flat-box-content">
        <form id="ProsesNotaPremiTreatyForm" enctype="multipart/form-data" autocomplete="off">
            <div>
                <div class="row form-group">
                    <div class="row col-sm-6">
                        <label class="col-sm-3" style="align-content: center;">Tanggal proses</label>
                        <div class="col-sm-9">
                            <kendo-datepicker for="tgl_proses" start="CalendarView.Year" 
                                              depth="CalendarView.Year" 
                                              format="MMMM yyyy"></kendo-datepicker>
                        </div>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="row col-sm-6">
                        <label class="col-sm-3">Kode COB</label>
                        <div class="col-sm-9">
                            <kendo-dropdownlist for="kd_cob" style="width: 100%" option-label="Pilih COB"
                                                datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                                <datasource type="DataSourceTagHelperType.Custom">
                                    <transport>
                                        <read url="@Url.Action("GetCOB", "ProsesNotaPremiTreaty")"/>
                                    </transport>
                                </datasource>
                            </kendo-dropdownlist>
                            <span asp-validation-for="kd_cob" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="row col-sm-6">
                        <div class="offset-8"></div>
                        <div class="col-sm-4">
                            <button type="button" id="btn-proses" class="btn btn-primary" style="width: 100%; padding: 7px 20px 7px 20px">
                                <span>Proses</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

