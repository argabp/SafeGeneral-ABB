@using Kendo.Mvc.UI
@using Kendo.Mvc.TagHelpers
@using ABB.Application.ProsesTutupTahun.Dtos
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Proses Tutup Tahun";
}

<script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    .div-box { padding-bottom: 1em; }
    .swal2-container { z-index: 10050 !important; }
    .breadcrumb-item + .breadcrumb-item::before {
        content: ">"; 
        padding: 0 .5rem; 
    }
</style>

<nav aria-label="breadcrumb">
   <ol class="breadcrumb" style="background: white;">
        <li class="breadcrumb-item"><a href="#">Accounting</a></li>
        <li class="breadcrumb-item active" aria-current="page">Proses Tutup Tahun</li>
    </ol>
</nav>

<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-9">
            Daftar Periode Tutup Tahun
        </div>
        <div class="col-md-3 text-right">
            <button class="flat-btn-primary" onclick="executeClosing()" style="width:100%;"> Proses Closing</button>
        </div>
    </div>

    <div class="flat-box-content">
        <div class="div-box">
            @(Html.Kendo().Grid<ProsesTutupTahunDto>()
                .Name("GridTutupTahun")
                .DataSource(dataSource => dataSource.Ajax()
                    .Read(read => read.Action("GetDaftarPeriode", "ProsesTutupTahun"))
                    .Model(model => model.Id(p => p.Tahun))
                    .PageSize(20)
                )
                .Columns(columns =>
                {
                    columns.Select().Width(50); // Checkbox
                    columns.Bound(col => col.Tahun).Width(150).Title("Tahun Buku");
                    columns.Bound(col => col.Status).Width(200).Title("Status")
                           .ClientTemplate(
                               "# if (Status == 'Open') { #" +
                               "<span class='badge badge-success' style='padding:8px; font-size:12px;'>#= Status #</span>" +
                               "# } else { #" +
                               "<span class='badge badge-danger' style='padding:8px; font-size:12px;'>#= Status #</span>" +
                               "# } #"
                           );
                })
                .Pageable(pager => pager.Refresh(true).Info(true))
                .PersistSelection()
                .Sortable()
                .Scrollable()
                .Height(450)
            )    
        </div>
    </div>
</div>

<script>
    function executeClosing() {
        var grid = $("#GridTutupTahun").data("kendoGrid");
        var selectedRows = grid.select();

        // 1. Validasi minimal pilih satu data
        if (selectedRows.length === 0) {
            showMessage("Peringatan", "Harap centang minimal satu Tahun yang ingin di-Closing!");
            return;
        }

        var commands = [];
        var adaYangBelumClose = false;

        // 2. Looping baris terpilih
        selectedRows.each(function () {
            var dataItem = grid.dataItem(this);
            if (dataItem.Status !== 'Open') {
                adaYangBelumClose = true;
            }
            commands.push({
                Tahun: dataItem.Tahun
            });
        });

        // 3. Validasi status kesiapan closing
        if (adaYangBelumClose) {
            showMessage("Peringatan", "Ada tahun yang berstatus 'Bulan Belum Close'. Harap tutup bulan 1 s/d 12 terlebih dahulu!");
            return;
        }

        // 4. Konfirmasi menggunakan showConfirmation bawaan sistem
        showConfirmation('Konfirmasi Tutup Tahun', 
            "Anda akan mengeksekusi Tutup Tahun untuk <b>" + commands.length + "</b> data terpilih. <br/>Proses ini akan merekap saldo ke bulan 0 tahun berikutnya. Lanjutkan?", 
            function () {
                
                // Tampilkan loading di atas Grid Tutup Tahun
                showProgressOnGrid('#GridTutupTahun');

                // 5. Eksekusi AJAX menggunakan ajaxPost helper
                ajaxPost("/ProsesTutupTahun/ProcessClosing", JSON.stringify(commands),
                    function (response) {
                        
                        // Matikan efek loading pada Grid
                        closeProgressOnGrid('#GridTutupTahun');

                        if (response.success) {
                            showMessage("Sukses", response.message);
                            
                            // Refresh grid & bersihkan seleksi checkbox
                            grid.dataSource.read();
                            grid.clearSelection();
                        } else {
                            showMessage("Error", response.message);
                        }
                    }
                );
            }
        );
    }
</script>