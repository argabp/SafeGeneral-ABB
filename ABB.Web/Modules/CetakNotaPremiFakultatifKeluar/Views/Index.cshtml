@using ABB.Application.CetakNotaPremiFakultatifKeluars.Queries
@using ABB.Application.Common.Dtos
@using Kendo.Mvc.UI
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cetak Nota Premi Fakultatif Keluar";
}
<script src="~/Modules/CetakNotaPremiFakultatifKeluar/JS/cetakNotaPremiFakultatifKeluar.js"></script>

<style>
    .div-box{
        padding-bottom: 1em;
    }
</style>
@{
    var jenisLaporans = ViewBag.JenisLaporan as List<DropdownOptionDto>;
}
<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-8">
            Cetak Nota Premi Fakultatif Keluar
        </div>

        <div class="col-md-4">
            <input type="text" class="search-field-top " id="SearchKeyword" placeholder="Search"/>
        </div>
    </div>

    <div class="flat-box-content">
        <div class="div-box">
            @(Html.Kendo().Grid<CetakNotaPremiFakultatifKeluarDto>()
                .Name("CetakNotaPremiFakultatifKeluarGrid")
                .DataSource(dataSource => dataSource.Ajax()
                    .Read(read => read.Action("GetCetakNotaPremiFakultatifKeluars", "CetakNotaPremiFakultatifKeluar").Data("searchFilterServerFiltering"))
                    .Model(model => model.Id(p => p.Id))
                )
                .Columns(columns =>
                {
                    columns.Bound(col => col.nm_cb).Width(150).Title("Nama Cabang");
                    columns.Bound(col => col.nm_cob).Width(150).Title("Nama COB");
                    columns.Bound(col => col.nm_scob).Width(150).Title("Nama SCOB");
                    columns.Bound(col => col.no_pol_ttg).Width(200).Title("Nomor Polis").ClientTemplate("#= formatNoPol(no_pol_ttg) #");
                    columns.Bound(col => col.no_rsk).Width(200).Title("No Resiko");
                    columns.Bound(col => col.nomor_nota).Width(200).Title("Nomor Nota");
                    columns.Bound(col => col.nm_ttg).Width(150).Title("Nama Tertanggung");
                    columns.Bound(col => col.nm_ttj).Width(150).Title("Nama Tertuju");
                    columns.Bound(col => col.nilai_nt).Width(150).Title("Nilai Nota").Format("{0:n2}");
                    columns.Bound(col => col.flag_posting).Width(150).Title("Flag Posting");
                })
                .Pageable(pager => pager
                    .Refresh(true)
                    .Info(true)
                    .PageSizes(true)
                )
                .ClientDetailTemplateId("template")
                .Sortable()
                .Filterable()
                .Scrollable()
                .Height(450)
                .Resizable(a=>a.Columns(true))
                .Events(ev => ev.DataBound("gridAutoFit"))
                ) 
        </div>
        
        <script id="template" type="text/kendo-tmpl">
            <form id="#=Id#" enctype="multipart/form-data" autocomplete="off">
                <div class="form-group row">
                    <div class="row col-sm-5">
                        <label class="col-sm-6">Jenis Laporan</label>
                        <div class="col-sm-6">
                            <select name="jenisLaporan" class="k-dropdown">
                                @foreach (var jenisLaporan in jenisLaporans)
                                {
                                    <option value="@jenisLaporan.Value">@jenisLaporan.Text</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <button type="button" onclick="viewReport(this)" class="btn btn-info space-right">
                    <span class="fa fa-print"></span> Preview
                </button>
            </form>
        </script>
    </div>
</div>

