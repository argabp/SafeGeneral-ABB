@using ABB.Application.KlaimAlokasiReasuransis.Queries
@using Kendo.Mvc.TagHelpers
@using Kendo.Mvc.UI
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Klaim Alokasi Reasuransi";
}
<script src="~/Modules/KlaimAlokasiReasuransi/JS/klaimAlokasiReasuransi.index.js"></script>

<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-8">
            Spreading of Loss (SOL)
        </div>
        <div class="col-md-4">
            <input type="text" class="search-field-top " id="SearchKeyword" placeholder="Search"/>
        </div>
    </div>

    <div class="flat-box-content">
        <div class="div-box">
            @(Html.Kendo().Grid<MutasiKlaimDto>()
                .Name("MutasiKlaimGrid")
                .DataSource(dataSource => dataSource.Ajax()
                    .Read(read => read.Action("GetMutasiKlaims", "KlaimAlokasiReasuransi").Data("searchFilterMutasiKlaim"))
                    .Model(model => model.Id(p => p.Id))
                )
                .Columns(columns =>
                {
                    columns.Command(command =>
                    {
                        command.Custom("View")
                            .Text("View")
                            .IconClass("fa fa-eye")
                            .HtmlAttributes(new { title = "View" })
                            .Click("OnClickViewMutasiKlaim");
                        // command.Custom("Edit")
                        //     .Text("Edit")
                        //     .IconClass("k-icon k-i-edit")
                        //     .HtmlAttributes(new { title = "Edit" })
                        //     .Click("OnClickEditMutasiKlaim");
                        command.Custom("AlokasiReasuransi")
                            .Text("Alokasi Reasuransi")
                            .IconClass("fa fa-plus")
                            .HtmlAttributes(new { title = "Alokasi Reasuransi" })
                            .Click("OnClickAlokasiReasuransi");
                        command.Custom("Closing")
                            .Text("Closing")
                            .IconClass("fa fa-lock")
                            .HtmlAttributes(new { title = "Closing" })
                            .Click("OnClickClosingMutasiKlaim");
                    }).Width(200).Title("Action");
                    columns.Bound(col => col.Id).Hidden();
                    columns.Bound(col => col.nm_cb).Width(150).Title("Nama Cabang");
                    columns.Bound(col => col.nm_cob).Width(150).Title("Nama COB");
                    columns.Bound(col => col.nm_scob).Width(150).Title("Nama Sub COB");
                    columns.Bound(col => col.no_pol_lama).Title("Nomor Polis").ClientTemplate("#= formatNoPol(no_pol_lama) #");
                    columns.Bound(col => col.nomor_register).Title("Nomor Berkas");
                    columns.Bound(col => col.no_mts).Width(150).Title("Nomor Mutasi");
                    columns.Bound(col => col.nm_tipe_mts).Width(150).Title("Tipe Mutasi");
                    columns.Bound(col => col.nm_ttg).Width(200).Title("Nama Tertanggung");
                    columns.Bound(col => col.tgl_mts).Width(150).Title("Tanggal Mutasi").Format("{0: dd-MM-yyyy}");
                    columns.Bound(col => col.tgl_closing).Width(150).Title("Tanggal Closing").Format("{0: dd-MM-yyyy}");
                    columns.Bound(col => col.tgl_reas).Width(150).Title("Tanggal Reas").Format("{0: dd-MM-yyyy}");
                    columns.Bound(col => col.nilai_ttl_kl).Width(150).Title("Nilai Klaim").Format("{0:n2}");
                    columns.Bound(col => col.nilai_total_klaim).Width(150).Title("Nilai Klaim Koas").Format("{0:n2}");
                    columns.Bound(col => col.sisa_alokasi).Width(150).Title("Sisa Alokasi").Format("{0:n2}");
                    columns.Bound(col => col.flag_reas).Width(150).Title("Flag Reas");
                })
                .Pageable(pager => pager
                    .Refresh(true)
                    .Info(true)
                    .PageSizes(true)
                )
                .ClientDetailTemplateId("template")
                .Sortable()
                .Filterable()
                .Scrollable()
                .Height(450)
                .Resizable(a => a.Columns(true))
                .Events(ev => ev.DataBound("OnMutasiKlaimDataBound"))

                )
        </div>
            
        <script id="template" type="text/kendo-tmpl">
            @(Html.Kendo().TabStrip()
                    .Name("tabStrip_#=id#")
                    .SelectedIndex(0)
                    .Animation(animation => animation.Open(open => open.Fade(FadeDirection.In)))
                    .Items(items =>
                    {
                        items.Add().Text("SOL").Content(@<text>
                            <div class="row col-sm-12">
                                <div class="col-md-1" id="add_btn_sol_#=id#">
                                    <button class="flat-btn-primary" style="height: 1em" onclick='OnClickAddSOL("#=kd_cb#", "#=kd_cob#", "#=kd_scob#", "#=kd_thn#", "#=no_kl#", "#=no_mts#", "#=sisa_alokasi#")'>Add SOL</button>
                                </div>
                            </div>
                            @(Html.Kendo().Grid<KlaimAlokasiReasuransiDto>()
                                .Name("grid_sol_#=id#")
                                .DataSource(dataSource => dataSource.Ajax()
                                    .Read(read => read.Action("GetKlaimAlokasiReasuransis", "KlaimAlokasiReasuransi", new
                                    {
                                        kd_cb = "#=kd_cb#", kd_cob = "#=kd_cob#", kd_scob = "#=kd_scob#", kd_thn = "#=kd_thn#", no_kl = "#=no_kl#", no_mts = "#=no_mts#"
                                        
                                    }).Data("searchFilterMutasiKlaim"))
                                    .Model(m => m.Id(p => p.Id))
                                )
                                .Columns(columns =>
                                {
                                    columns.Command(command =>
                                    {
                                        command.Custom("EditSOL")
                                            .Text("Edit")
                                            .IconClass("k-icon k-i-edit")
                                            .HtmlAttributes(new { title = "Edit" })
                                            .Click("OnClickEditSOL");
                                        command.Custom("DeleteSOL")
                                            .Text("Delete")
                                            .IconClass("k-icon k-i-delete")
                                            .HtmlAttributes(new { title = "Delete" })
                                            .Click("onDeleteSOL");
                                    }).Width(100).Title("Action");
                                    columns.Bound(col => col.nm_jns_sor).Width(150).Title("Jenis SOR");
                                    columns.Bound(col => col.nm_rk_sor).Width(150).Title("Nama Rekanan Sor").ClientFooterTemplate("<div>Total Share dan Klaim</div>");
                                    columns.Bound(col => col.pst_share).Width(150).Title("Share (%)").Format("{0:n6}").ClientFooterTemplate("<div class='sum-pst_share'>0.000000</div>");
                                    columns.Bound(col => col.nilai_kl).Width(150).Title("Nilai Klaim").Format("{0:n4}").ClientFooterTemplate("<div class='sum-nilai_kl'>0.000000</div>");
                                    columns.Bound(col => col.flag_nota).Width(150).Title("Flag Nota");
                                    columns.Bound(col => col.flag_cash_call).Width(150).Title("Flag Cash Call");
                                    
                                })
                                .Pageable(pager => pager
                                    .Refresh(true)
                                    .Info(true)
                                    .PageSizes(true)
                                )
                                .Sortable()
                                .Selectable()
                                .Filterable()
                                .Scrollable()
                                .Height(380)
                                .Resizable(a=>a.Columns(true))
                                .Events(ev => ev.DataBound("OnKlaimAlokasiReasuransiDataBound"))
                                .ToClientTemplate())
                        </text>
                        );
                        items.Add().Text("SOL XOL").Content(@<text>
                            <div class="row col-sm-12">
                                <div class="col-md-1" id="add_btn_xol_#=id#">
                                    <button class="flat-btn-primary" style="height: 1em" onclick='OnClickAddSOLXOL("#=kd_cb#", "#=kd_cob#", "#=kd_scob#", "#=kd_thn#", "#=no_kl#", "#=no_mts#")'>Add SOL XOL</button>
                                </div>
                            </div>
                            @(Html.Kendo().Grid<KlaimAlokasiReasuransiXLDto>()
                                .Name("grid_sol_xol_#=id#")
                                .DataSource(dataSource => dataSource.Ajax()
                                    .Read(read => read.Action("GetKlaimAlokasiReasuransiXLs", "KlaimAlokasiReasuransi", new
                                    {
                                        kd_cb = "#=kd_cb#", kd_cob = "#=kd_cob#", kd_scob = "#=kd_scob#", kd_thn = "#=kd_thn#", no_kl = "#=no_kl#", no_mts = "#=no_mts#"
                                        
                                    }).Data("searchFilterMutasiKlaim"))
                                    .Model(m => m.Id(p => p.Id))
                                )
                                .Columns(columns =>
                                {
                                    columns.Command(command =>
                                    {
                                        command.Custom("EditSOLXOL")
                                            .Text("Edit")
                                            .IconClass("k-icon k-i-edit")
                                            .HtmlAttributes(new { title = "Edit" })
                                            .Click("OnClickEditSOLXOL");
                                        command.Custom("DeleteSOLXOL")
                                            .Text("Delete")
                                            .IconClass("k-icon k-i-delete")
                                            .HtmlAttributes(new { title = "Delete" })
                                            .Click("onDeleteSOLXOL");
                                    }).Width(100).Title("Action");
                                    columns.Bound(col => col.nm_jns_sor).Width(150).Title("Jenis SOR");
                                    columns.Bound(col => col.nm_kontr).Width(150).Title("Nama Kontrak");
                                    columns.Bound(col => col.nilai_kl).Width(150).Title("Nilai Klaim").Format("{0:n2}");
                                    columns.Bound(col => col.nilai_reinst).Width(150).Title("Nilai Reinstate").Format("{0:n2}");
                                    
                                })
                                .Pageable(pager => pager
                                    .Refresh(true)
                                    .Info(true)
                                    .PageSizes(true)
                                )
                                .Sortable()
                                .Selectable()
                                .Filterable()
                                .Scrollable()
                                .Height(380)
                                .Resizable(a=>a.Columns(true))
                                .Events(ev => ev.DataBound("OnKlaimAlokasiReasuransiXOLDataBound"))
                                .ToClientTemplate())
                                                           </text>
                        );
                    })
                    .ToClientTemplate())
        </script>

        @(Html.Kendo().Window()
                    .Name("KlaimAlokasiReasuransiWindow")
                    .Title("Klaim Alokasi Reasuransi Page")
                    .Width(800)
                    .Modal(true)
                    .Visible(false)
                    .Draggable(true)
            )
    </div>
</div>
