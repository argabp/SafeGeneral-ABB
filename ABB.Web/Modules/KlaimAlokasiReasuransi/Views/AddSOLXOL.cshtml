@model ABB.Web.Modules.KlaimAlokasiReasuransi.Models.KlaimAlokasiReasuransiXLViewModel
@using Kendo.Mvc.UI
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc
@addTagHelper *, ABB.Web

<script src="~/Modules/KlaimAlokasiReasuransi/JS/klaimAlokasiReasuransi.sol.xol.js"></script>

@{
    var nomor_register = Model.kd_cb.Trim() + "." + Model.kd_cob.Trim() +
                          Model.kd_scob.Trim() + "." + Model.kd_thn.Trim() + "." + Model.no_kl.Trim();
}

<div class="window-body" style="background-color: lightgray">
    <form id="KlaimAlokasiReasuransiXLForm" enctype="multipart/form-data" autocomplete="off">
        @Html.HiddenFor(h => h.kd_cb)
        @Html.HiddenFor(h => h.kd_cob)
        @Html.HiddenFor(h => h.kd_scob)
        @Html.HiddenFor(h => h.kd_thn)
        @Html.HiddenFor(h => h.no_kl)
        @Html.HiddenFor(h => h.no_mts)
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-4">Nomor Register Klaim</label>
                <div class="col-sm-8">
                    <kendo-textbox name="temp_nomor_register" value="@nomor_register" readonly="true" style="width: 100%"/>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-4">Jenis Sor</label>
                <div class="col-sm-8">
                    <kendo-dropdownlist for="kd_jns_sor" style="width: 100%" option-label="Pilih Jenis Sor"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetJenisSor", "KlaimAlokasiReasuransi")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-4">Kontrak</label>
                <div class="col-sm-8">
                    <kendo-dropdownlist for="kd_kontr" style="width: 100%" option-label="Pilih Kontrak"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetKontrakSOR", "KlaimAlokasiReasuransi")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                    <span asp-validation-for="kd_kontr" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-4">Nilai Klaim</label>
                <div class="col-sm-8">
                    <kendo-numerictextbox decimals="2" spinners="false" for="nilai_kl" style="width: 100%;"/>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-12">
                <label class="col-sm-4">Reinstate</label>
                <div class="col-sm-8">
                    <kendo-numerictextbox decimals="2" spinners="false" for="nilai_reinst" style="width: 100%;"/>
                </div>
            </div>
        </div>
    </form>

    <div class="window-footer">
        <button type="button" id="btn-save-klaimAlokasiReasuransiXL" class="btn btn-success space-right">
            <span class="fa fa-save"></span> Save
        </button>
    </div>
</div>