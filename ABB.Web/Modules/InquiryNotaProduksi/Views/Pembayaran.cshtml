@model ABB.Web.Modules.InquiryNotaProduksi.Models.InquiryNotaProduksiViewModel
@using Kendo.Mvc.UI
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

<style>
    /* Styling agar menyerupai kertas dokumen A4 */
    .document-paper {
        background: white;
        padding: 10px;
        margin: 0 auto;
        font-family: 'Arial', sans-serif;
        color: black;
        border: 1px solid #ccc;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        max-width: 950px; /* Dikit dilebarkan biar muat banyak kolom */
        font-size: 10px;  /* Font dikecilkan dikit biar tabel rincian aman */
    }
    .doc-header-table {
        width: 100%;
        margin-bottom: 10px;
        font-size: 12px;
    }
    .doc-header-table td {
        padding: 4px 8px;
        vertical-align: top;
    }
    .doc-header-table .bold-label {
        font-weight: bold;
    }
    /* Mengatur lebar kolom header Kiri dan Kanan */
    .col-label-left { width: 15%; }
    .col-value-left { width: 45%; }
    .col-label-right { width: 15%; }
    .col-value-right { width: 25%; }

    .doc-details-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
    }
    .doc-details-table th, .doc-details-table td {
        border: 1px solid #000;
        padding: 6px;
        text-align: center;
    }
    .doc-details-table th {
        background-color: #f2f2f2;
        font-weight: bold;
    }
    .text-left { text-align: left !important; }
    .text-right { text-align: right !important; }
</style>

<div class="window-body">
    <div style="text-align: right; margin-bottom: 15px;">
        <button type="button" class="btn btn-danger" onclick="exportBuktiToPDF()">
            <i class="fa fa-file-pdf-o"></i> Simpan sebagai PDF
        </button>
    </div>

    <div id="pdf-document-area" class="document-paper">
        
        <h3 style="text-align:center; text-decoration: underline; margin-bottom: 30px; font-size: 16px;">BUKTI PEMBAYARAN</h3>

        <table class="doc-header-table">
            <tr>
                <td class="bold-label col-label-left">NO. POLIS</td>
                <td class="col-value-left">: @Model.InquiryNotaProduksiHeader.no_pl</td>
                <td class="bold-label col-label-right">COB</td>
                <td class="col-value-right">: @Model.InquiryNotaProduksiHeader.kd_ass2</td>
            </tr>
            <tr>
                <td class="bold-label">TERTANGGUNG</td>
                <td>: @Model.InquiryNotaProduksiHeader.nm_cust</td>
                <td class="bold-label">PEMBAWA POS</td>
                <td>: @(Model.InquiryNotaProduksiHeader.nm_pos)</td> 
            </tr>
            <tr>
                <td class="bold-label">CEDING</td>
                <td>: @Model.InquiryNotaProduksiHeader.nm_cust2</td>
                <td class="bold-label">AGEN/BROKER</td>
                <td>: @(Model.InquiryNotaProduksiHeader.nm_brok)</td> 
            </tr>
        </table>

        <table class="doc-details-table">
            <thead>
                <tr>
                    <th width="2%">NO.</th>
                    <th width="10%">TANGGAL</th>
                    <th width="20%">NO. NOTA</th>
                    <th width="15%">NO. BUKTI</th>
                    <th width="10%">NO. REFF</th> 
                    <th width="10%">TGL BAYAR</th>
                    <th width="20%">KETERANGAN</th>
                    <th width="3%">D/K</th>
                    <th width="10%">JUMLAH (Rp)</th>
                </tr>
            </thead>
           <tbody>
                @{
                    int urut = 1;
                    decimal totalSaldo = 0;
                    
                    // 1. Ambil Nilai Nota Asli dan D/K-nya
                    decimal nilaiNota = Model.InquiryNotaProduksiHeader.jumlah ?? 0;
                    string notaDK = Model.InquiryNotaProduksiHeader.d_k?.Trim().ToUpper() ?? "D";
                    
                    // Saldo awal = Nilai Nota (biarkan sesuai aslinya, minus ya minus, plus ya plus)
                    totalSaldo = nilaiNota;

                    // Baris Pertama (Nilai Nota)
                    <tr>
                        <td>@urut</td>
                        <td>@(Model.InquiryNotaProduksiHeader.date_input?.ToString("dd/MM/yyyy"))</td>
                        <td>@Model.InquiryNotaProduksiHeader.no_nd</td>
                        <td>@Model.InquiryNotaProduksiHeader.no_nd</td> 
                        <td>@Model.InquiryNotaProduksiHeader.no_ref</td> 
                        <td>-</td>
                        <td class="text-left">NILAI NOTA</td>
                        <td>@notaDK</td>
                        <td class="text-right">@string.Format("{0:N2}", nilaiNota)</td>
                    </tr>
                    urut++;

                    // [LOGIC SAKTI]: Cara melunasi Saldo
                    // Kalau Nota aslinya Kredit (K) -> Nilainya biasa Minus. Untuk melunasinya, saldo harus di-TAMBAH (+=) pembayaran.
                    // Kalau Nota aslinya Debet (D) -> Nilainya biasa Plus. Untuk melunasinya, saldo harus di-KURANGI (-=) pembayaran.
                    bool isNotaKredit = notaDK == "K";

                    // 2. Looping Pembayaran Kas
                    if (Model.PembayaranKasList != null)
                    {
                        foreach (var item in Model.PembayaranKasList)
                        {
                            decimal bayar = item.TotalDlmRupiah ?? 0;
                            if (isNotaKredit) { totalSaldo += bayar; } else { totalSaldo -= bayar; }
                            
                            <tr>
                                <td>@urut</td>
                                <td>@(Model.InquiryNotaProduksiHeader.date_input?.ToString("dd/MM/yyyy"))</td>
                                <td>@Model.InquiryNotaProduksiHeader.no_nd</td>
                                <td>@item.NoVoucher</td>
                                <td>-</td> 
                                <td>@(item.TanggalVoucher?.ToString("dd/MM/yyyy"))</td>
                                <td class="text-left">PEMBAYARAN KAS</td>
                                <td>@(isNotaKredit ? "D" : "K")</td> <td class="text-right">@string.Format("{0:N2}", bayar)</td>
                            </tr>
                            urut++;
                        }
                    }

                    // 3. Looping Pembayaran Bank
                    if (Model.PembayaranBankList != null)
                    {
                        foreach (var item in Model.PembayaranBankList)
                        {
                            decimal bayar = item.TotalDlmRupiah ?? 0;
                            if (isNotaKredit) { totalSaldo += bayar; } else { totalSaldo -= bayar; }

                            <tr>
                                <td>@urut</td>
                                <td>@(Model.InquiryNotaProduksiHeader.date_input?.ToString("dd/MM/yyyy"))</td>
                                <td>@Model.InquiryNotaProduksiHeader.no_nd</td>
                                <td>@item.NoVoucher</td>
                                <td>-</td>
                                <td>@(item.TanggalVoucher?.ToString("dd/MM/yyyy"))</td>
                                <td class="text-left">PEMBAYARAN BANK</td>
                                <td>@(isNotaKredit ? "D" : "K")</td>
                                <td class="text-right">@string.Format("{0:N2}", bayar)</td>
                            </tr>
                            urut++;
                        }
                    }

                    // 4. Looping Pembayaran Piutang
                    if (Model.PembayaranPiutangList != null)
                    {
                        foreach (var item in Model.PembayaranPiutangList)
                        {
                            decimal bayar = item.TotalBayarRp ?? 0;
                            if (isNotaKredit) { totalSaldo += bayar; } else { totalSaldo -= bayar; }

                            <tr>
                                <td>@urut</td>
                                <td>@(Model.InquiryNotaProduksiHeader.date_input?.ToString("dd/MM/yyyy"))</td>
                                <td>@Model.InquiryNotaProduksiHeader.no_nd</td>
                                <td>@item.NomorBukti</td>
                                <td>-</td>
                                <td>@(item.Tanggal?.ToString("dd/MM/yyyy"))</td>
                                <td class="text-left">PEMBAYARAN PIUTANG</td>
                                <td>@(isNotaKredit ? "D" : "K")</td>
                                <td class="text-right">@string.Format("{0:N2}", bayar)</td>
                            </tr>
                            urut++;
                        }
                    }
                }
            </tbody>
        </table>

        <div style="text-align: right; font-weight: bold; font-size: 14px; margin-top: 10px;">
            Saldo : Rp @string.Format("{0:N2}", totalSaldo)
        </div>

    </div>
</div>

<script>
    function exportBuktiToPDF() {
        kendo.drawing.drawDOM("#pdf-document-area", {
            paperSize: "A4",
            landscape: true,
            margin: { top: "1cm", bottom: "1cm", left: "0.5cm", right: "0.5cm" },
            scale: 0.85, // Scale diperkecil sedikit lagi biar tabel yang agak panjang tidak terpotong ke samping
            keepTogether: ".doc-details-table tr" 
        }).then(function(group) {
            kendo.drawing.pdf.saveAs(group, "Bukti_Pembayaran_@(Model.InquiryNotaProduksiHeader.no_nd).pdf");
        });
    }
</script>