@using ABB.Application.CancelPostingNotaPremiFakultatifKeluars.Queries
@using Kendo.Mvc.UI
@using Microsoft.Extensions.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc

@inject IConfiguration Configuration

@{
    Layout = "~/Modules/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cancel Posting Nota Premi Fakultatif Keluar";
}
<script src="~/Modules/CancelPostingNotaPremiFakultatifKeluar/JS/cancelPostingNotaPremiFakultatifKeluar.js"></script>

<style>
    .div-box{
        padding-bottom: 1em;
    }
</style>
<div class="flat-box">
    <div class="row">
        <div class="flat-box-title col-md-4">
            Cancel Posting Nota Premi Fakultatif Keluar
        </div>

        <div class="col-md-4">
            <input type="text" class="search-field-top " id="SearchKeyword" placeholder="Search"/>
        </div>

        <div class="col-md-2">
            <button class="flat-btn-primary" onclick="cancelPostingNotaPremiFakultatifKeluar()">Cancel Posting</button>
        </div>
        @* <div class="col-md-2"> *@
        @*     <button class="flat-btn-primary" onclick="accountingPostingNotaPremiFakultatifKeluar()">Posting Accounting</button> *@
        @* </div> *@
    </div>

    <div class="flat-box-content">
        <div class="div-box">
            @(Html.Kendo().Grid<CancelPostingNotaPremiFakultatifKeluarDto>()
                .Name("CancelPostingNotaPremiFakultatifKeluarGrid")
                .DataSource(dataSource => dataSource.Ajax()
                    .Read(read => read.Action("GetCancelPostingNotaPremiFakultatifKeluars", "CancelPostingNotaPremiFakultatifKeluar").Data("searchFilterCancelPostingNotaPremiFakultatifKeluar"))
                    .Model(model => model.Id(p => p.nomor_nota))
                )
                .Columns(columns =>
                {
                    columns.Select().Width(50);
                    columns.Bound(col => col.no_pol).Width(150).Title("Nomor Polis");
                    columns.Bound(col => col.nm_ttg).Width(150).Title("Nama Tertanggung");
                    columns.Bound(col => col.nomor_nota).Width(200).Title("Nomor Nota");
                    columns.Bound(col => col.nm_ttj).Width(150).Title("Nama Tertuju");
                    columns.Bound(col => col.tgl_nt).Width(150).Title("Tanggal Nota").Format("{0: dd-MM-yyyy}");
                    columns.Bound(col => col.nilai_nt).Width(150).Title("Nilai Nota").Format("{0:n4}");;
                })
                .Pageable(pager => pager
                    .Refresh(true)
                    .Info(true)
                    .PageSizes(true)
                )
                .PersistSelection()
                .Sortable()
                .Filterable()
                .Scrollable()
                .Height(450)
                .Resizable(a=>a.Columns(true))
                .Events(ev => ev.DataBound("gridAutoFit").Change("onChangeGridCancelPostingNotaPremiFakultatifKeluar"))
        
                )    
        </div>
    </div>
</div>

