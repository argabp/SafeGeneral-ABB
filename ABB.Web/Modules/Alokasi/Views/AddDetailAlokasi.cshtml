@using System.Globalization
@using Kendo.Mvc.UI
@model ABB.Web.Modules.Alokasi.Models.DetailAlokasiViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Kendo.Mvc
@addTagHelper *, ABB.Web

<script src="~/Modules/Alokasi/JS/alokasi.detail.form.js"></script>

<style>
    p {
        margin: 0px;
        padding: 0px;
    }
    label {
        align-content: center;
    }
</style>

<div class="window-body">
        <form id="AlokasiForm" enctype="multipart/form-data" autocomplete="off">
        @Html.HiddenFor(h => h.kd_grp_sor)
        @Html.HiddenFor(h => h.kd_grp_sb_bis)
        @Html.HiddenFor(h => h.no_pol)
        @Html.HiddenFor(h => h.no_updt_reas)
        @Html.HiddenFor(h => h.no_updt)
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Jenis Sor</label>
                <div class="col-sm-6">
                    <kendo-dropdownlist for="kd_jns_sor" style="width: 100%" on-change="OnKodeJenisSorChange" option-label="Pilih Jenis Sor"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetJenisSor", "Alokasi")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <input type="hidden" id="temp_kd_rk_sor" value="@Model.kd_rk_sor">
                <label class="col-sm-6">Kode Sor</label>
                <div class="col-sm-6">
                    <kendo-dropdownlist for="kd_rk_sor" style="width: 100%"
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetRekananSor", "Alokasi")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">TSI</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox decimals="2" spinners="false" for="nilai_ttl_ptg_reas" on-change="OnPtgReasChange" style="width: 100%"/>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Share (%)</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox decimals="2" spinners="false" for="pst_share" on-change="OnPstShareChange" style="width: 100%"/>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Premi</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox decimals="2" spinners="false" for="nilai_prm_reas" style="width: 100%"/>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Pst (%)</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox decimals="2" spinners="false" for="pst_kms_reas" on-change="OnPstKmsReasChange" style="width: 100%"/>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="row col-sm-6">
                <label class="col-sm-6">Komisi</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox decimals="2" spinners="false" for="nilai_kms_reas" style="width: 100%"/>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-6 row">
                <label class="col-sm-6">Rate Adjustment</label>
                <div class="col-sm-3">
                    <kendo-numerictextbox spinners="false" decimals="4" format="n4" for="pst_adj_reas" on-change="OnAdjReasChange" style="width: 100%"/>
                </div>
                <div class="col-sm-3">
                    <kendo-dropdownlist for="stn_adj_reas" style="width: 100%" on-change="OnAdjReasChange" 
                                        datavaluefield="Value" datatextfield="Text" filter="FilterType.Contains">
                        <datasource type="DataSourceTagHelperType.Custom">
                            <transport>
                                <read url="@Url.Action("GetRatePremi", "Alokasi")"/>
                            </transport>
                        </datasource>
                    </kendo-dropdownlist>
                </div>
            </div>
        </div>
        <div class="form-group row" id="premiAdjustmentDiv" style="display: none">
            <div class="row col-sm-6">
                <label class="col-sm-6">Premi Adjustment</label>
                <div class="col-sm-6">
                    <kendo-numerictextbox decimals="2" spinners="false" for="nilai_adj_reas" style="width: 100%"/>
                </div>
            </div>
        </div>
    </form>

    <div class="window-footer">
        <button type="button" id="btn-save-alokasiDetail" class="btn btn-success space-right">
            <span class="fa fa-save"></span> Save
        </button>
    </div>
</div>